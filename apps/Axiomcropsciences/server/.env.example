PORT=5001
MONGO_URI=mongodb://localhost:27017/axiomcropsciences
JWT_SECRET=your_jwt_secret_here
# Comma-separated list of frontend origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-production-domain.com

# SwiftZap SMS OTP - until SWIFTZAP_API_KEY and SWIFTZAP_TEMPLATE_ID are set, OTP runs in dev mode
# (no SMS sent; the code is returned in the API response for testing).
SWIFTZAP_BASE_URL=https://signetaiserver.swiftzap.in/api
SWIFTZAP_API_KEY=
SWIFTZAP_TEMPLATE_ID=
# Must match your approved DLT template. Use {{OTP}} or {#var#} where the code belongs.
SWIFTZAP_OTP_MESSAGE=Dear customer, your OTP is {{OTP}}.
